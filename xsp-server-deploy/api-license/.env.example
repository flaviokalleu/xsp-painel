# API de licenciamento — variáveis de ambiente
APP_ENV=production
LISTEN_ADDR=:8443

# Postgres
DATABASE_URL=postgres://xsp:CHANGE_ME@db:5432/xsp_license?sslmode=disable

# Redis
REDIS_URL=redis://redis:6379/0

# Segredos (gere com: openssl rand -hex 32)
HMAC_PUBLIC_SECRET=CHANGE_ME_32_BYTES_HEX
JWT_SECRET=CHANGE_ME_32_BYTES_HEX
ADMIN_TOKEN=CHANGE_ME_LONG_RANDOM

# Ed25519 (gere com: openssl genpkey -algorithm ed25519 -out priv.pem)
# Cole o conteúdo em base64 (cat priv.pem | base64 -w0)
ED25519_PRIVATE_KEY_B64=
ED25519_PUBLIC_KEY_B64=

# Master key da release atual (gerada pelo pipeline de build do painel)
RELEASE_VERSION=10.0.3
RELEASE_MASTER_KEY=CHANGE_ME_64_HEX_CHARS

# Registry Docker privado
REGISTRY_URL=registry.seudominio.com
REGISTRY_USER=license
REGISTRY_PASSWORD=CHANGE_ME

# Stripe (opcional)
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

# Mercado Pago (opcional)
MP_ACCESS_TOKEN=
MP_WEBHOOK_SECRET=
MP_DEFAULT_PLAN=pro
MP_PERIOD_DAYS=30

# TLS (deixe vazio se estiver atrás de proxy/Caddy)
TLS_CERT_FILE=
TLS_KEY_FILE=
