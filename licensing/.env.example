###############################################################################
#  XSP LICENSING — Variáveis do stack Docker
#  Copie para .env (cp .env.example .env) e ajuste.
#  Para gerar todos os segredos: ./bootstrap-secrets.sh
###############################################################################

# Domínios — DEVEM já estar apontando para esta VPS
API_HOST=license.seudominio.com
ADM_HOST=admin.seudominio.com
REG_HOST=registry.seudominio.com
PUBLIC_HOST=seudominio.com
PORTAL_HOST=conta.seudominio.com
ACME_EMAIL=voce@seudominio.com

# Mercado Pago — link do produto de assinatura (opcional, aparece no portal)
MP_RENEW_LINK=https://mpago.la/seu-link-de-pagamento

# Versão do painel (atualize sempre que publicar release)
PANEL_VERSION=10.0.3

# ─── Credenciais geradas (não edite manualmente, use bootstrap-secrets.sh) ───
DB_PASS=
ADMIN_TOKEN=
HMAC_PUBLIC_SECRET=
JWT_SECRET=
RELEASE_MASTER_KEY=
ED25519_PRIVATE_KEY_B64=
ED25519_PUBLIC_KEY_B64=

# Registry privado
REG_USER=license
REG_PASS=

# Admin dashboard
ADM_USER=admin
ADM_PASS=
